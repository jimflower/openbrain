# Database Configuration
DATABASE_URL=postgresql://openbrain:your_password@localhost:5432/openbrain

# Server Ports
API_PORT=3000
MCP_PORT=3001

# Security
# Generate with: openssl rand -hex 32
ACCESS_KEY=your-secure-random-access-key-here

# Embedding Configuration
# Options: local, api, hybrid
EMBEDDING_MODE=local

# Ollama settings (for local embeddings)
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Alternative models:
# - mxbai-embed-large (334M params, 1024 dims)
# - all-minilm (23M params, 384 dims) - faster but less accurate

# OpenAI settings (for API embeddings - optional)
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Metadata Extraction Configuration
# Options: local, api, skip
METADATA_MODE=local

# Ollama model for metadata (when METADATA_MODE=local)
OLLAMA_LLM_MODEL=llama3:8b
# Alternatives: mistral, phi3, gemma

# API models for metadata (when METADATA_MODE=api)
# Will use first available key
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# Metadata extraction model preference (when using API)
# Options: claude-haiku, gpt-4o-mini, gemini-flash
METADATA_API_MODEL=claude-haiku

# Logging
LOG_LEVEL=info
# Options: error, warn, info, debug

# Environment
NODE_ENV=production
